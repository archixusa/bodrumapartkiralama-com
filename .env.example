# Public site URL — Vercel ortamına göre değiştir
NEXT_PUBLIC_SITE_URL=https://bodrumapartkiralama.com

# Rezervasyon e-posta bildirimi (Resend)
RESEND_API_KEY=
FROM_EMAIL=no-reply@bodrumapartkiralama.com
NOTIFY_EMAIL=info@bodrumapartkiralama.com

# Analytics & Tag yönetimi (opsiyonel — sonradan eklenecek)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Supabase (multi-site rezervasyon sistemi)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Content hub (DB-backed content engine) — preview & revalidate secrets
# Used by /api/preview (Next.js draft mode) and /api/revalidate (on-publish ISR).
CONTENT_PREVIEW_SECRET=
CONTENT_REVALIDATE_SECRET=
